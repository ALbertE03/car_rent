---
import logoSvg from "../assets/SJ-_-ASSOCIATES-1.svg";
---

<header>
  <div class="container header-inner">
    <a href="/" class="logo">
      <div class="logo-bg">
        <img src={logoSvg.src} alt="SJ & Associates" width="40" height="40" />
      </div>
      <span class="logo-text">SJ & Associates</span>
    </a>
    <nav>
      <a href="/#vehicles">Vehicles</a>
      <a href="/#about">About</a>
      <a href="/#contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-bg {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .logo-bg img {
    filter: invert(1);
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .logo-text {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.3px;
  }

  nav {
    display: flex;
    gap: 32px;
  }

  nav a {
    font-size: 14px;
    font-weight: 500;
    color: #666;
    transition: color 0.2s;
  }

  nav a:hover {
    color: #1a1a1a;
  }

  @media (max-width: 768px) {
    nav a {
      font-size: 13px;
    }
    nav {
      gap: 20px;
    }
    .logo-text {
      font-size: 16px;
    }
  }
</style>
