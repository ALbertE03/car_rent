---
import logoSvg from "../assets/file-1.svg";
---

<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <img src={logoSvg.src} alt="SJ & Associates" />
    </a>
    <div class="header-banner">
      <h1>Premium Car Rental</h1>
      <p>
        Suzuki Ignis & Nissan Cube. Reliable vehicles, transparent pricing,
        exceptional service.
      </p>
    </div>
  </div>
</header>

<style>
  header {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
    color: white;
    padding: 40px 48px;
    min-height: 380px;
    display: flex;
    align-items: center;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 64px;
  }

  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo img {
    width: 140px;
    height: 140px;
    object-fit: contain;
    border-radius: 50%;
  }

  .header-banner {
    max-width: 580px;
  }

  .header-banner h1 {
    font-size: 46px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1.2px;
    margin-bottom: 18px;
  }

  .header-banner p {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
  }

  @media (max-width: 768px) {
    header {
      min-height: auto;
      padding: 32px 20px;
    }

    .header-inner {
      flex-direction: column;
      text-align: center;
      gap: 28px;
    }

    .logo img {
      width: 100px;
      height: 100px;
    }

    .header-banner h1 {
      font-size: 30px;
    }

    .header-banner p {
      font-size: 16px;
    }
  }
</style>
