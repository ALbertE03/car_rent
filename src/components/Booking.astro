---
import type { Car } from "../data/cars";

export interface Props {
  car: Car;
}

const { car } = Astro.props;
---

<section class="booking-section" id="booking">
  <div class="booking-container">
    <div class="booking-header">
      <h2>Book This Vehicle</h2>
      <p class="booking-subtitle">
        Select your dates and reserve online
      </p>
    </div>

    <div class="booking-form">
      <div class="form-group">
        <label for="startDateInput">Check-in Date</label>
        <input type="date" id="startDateInput" class="form-input" min={new Date().toISOString().slice(0,10)} />
      </div>

      <div class="days-selector">
        <label>Number of days</label>
        <div class="days-control">
          <button id="decDays" class="days-btn" type="button">−</button>
          <span id="dayCount" class="days-value">1</span>
          <button id="incDays" class="days-btn" type="button">+</button>
        </div>
      </div>

      <div class="price-breakdown">
        <div class="price-row">
          <span>${car.pricePerDay} &times; <span id="calcDays">1</span> day(s)</span>
          <span>$<span id="subtotal">{car.pricePerDay}</span></span>
        </div>
        <div class="price-row total">
          <span>Total</span>
          <span>$<span id="total">{car.pricePerDay}</span></span>
        </div>
      </div>

      <button id="bookBtn" class="pay-btn" disabled type="button">
        <span id="bookText">Book Now</span>
        <span id="bookLoader" class="loader" style="display:none"></span>
      </button>
      <p id="bookError" class="book-error"></p>
      <p id="bookSuccess" class="book-success" style="display:none"></p>
    </div>
  </div>
  <div id="bookingData" data-slug={car.slug} data-price={car.pricePerDay} style="display:none"></div>
</section>

<script>
  const el = document.getElementById("bookingData") as HTMLDivElement;
  let pricePerDay = parseInt(el.dataset.price || "0");
  const carSlug = el.dataset.slug || "";

  const backendBase = () => {
    const url = localStorage.getItem("backend_url") || "";
    return url.replace(/\/payments\/create-checkout-session$/, "").replace(/\/$/, "") || "http://localhost:8000/api/v1";
  };

  (async () => {
    try {
      const res = await fetch(`${backendBase()}/cars/${carSlug}`);
      const data = await res.json();
      if (data.price_per_day) {
        pricePerDay = data.price_per_day;
        document.querySelectorAll("[data-price]").forEach(el => (el as HTMLElement).dataset.price = String(data.price_per_day));
        updatePrice();
      }
    } catch {}
  })();

  let startDate: string = "";
  let dayCount = 1;

  function isLoggedIn() {
    return !!localStorage.getItem("access_token");
  }

  function getApiToken() {
    return localStorage.getItem("access_token") || "";
  }

  function getBackendUrl() {
    return localStorage.getItem("backend_url") || "http://localhost:8000/api/v1/payments/create-checkout-session";
  }

  const startDateInput = document.getElementById("startDateInput") as HTMLInputElement;
  const dayCountEl = document.getElementById("dayCount") as HTMLSpanElement;
  const calcDays = document.getElementById("calcDays") as HTMLSpanElement;
  const subtotal = document.getElementById("subtotal") as HTMLSpanElement;
  const total = document.getElementById("total") as HTMLSpanElement;
  const bookBtn = document.getElementById("bookBtn") as HTMLButtonElement;
  const bookText = document.getElementById("bookText") as HTMLSpanElement;
  const bookError = document.getElementById("bookError") as HTMLParagraphElement;

  function updatePrice() {
    if (!startDate) {
      bookBtn.disabled = true;
      bookBtn.textContent = "Book Now";
      return;
    }
    calcDays.textContent = String(dayCount);
    const sub = pricePerDay * dayCount;
    subtotal.textContent = String(sub);
    total.textContent = String(sub);
    bookBtn.disabled = false;
    bookBtn.textContent = `Book Now — $${sub}`;
  }

  startDateInput.addEventListener("change", () => {
    startDate = startDateInput.value;
    updatePrice();
  });

  document.getElementById("incDays")?.addEventListener("click", () => {
    dayCount++;
    dayCountEl.textContent = String(dayCount);
    updatePrice();
  });

  document.getElementById("decDays")?.addEventListener("click", () => {
    if (dayCount > 1) {
      dayCount--;
      dayCountEl.textContent = String(dayCount);
      updatePrice();
    }
  });

  updatePrice();

  bookBtn.addEventListener("click", async () => {
    if (!startDate) return;
    if (!isLoggedIn()) {
      document.dispatchEvent(new CustomEvent("open-auth", { detail: { form: "login" } }));
      return;
    }
    const loader = document.getElementById("bookLoader") as HTMLSpanElement;
    const success = document.getElementById("bookSuccess") as HTMLParagraphElement;

    bookBtn.disabled = true;
    bookText.textContent = "Processing...";
    loader.style.display = "inline-block";
    bookError.textContent = "";
    success.style.display = "none";

    try {
      const headers: Record<string, string> = { "Content-Type": "application/json" };
      const token = getApiToken();
      if (token) headers["Authorization"] = `Bearer ${token}`;

      const res = await fetch(getBackendUrl(), {
        method: "POST",
        headers,
        body: JSON.stringify({
          car: carSlug,
          startDate: startDate,
          days: dayCount,
          amount: pricePerDay * dayCount,
        }),
      });

      const data = await res.json();

      if (!res.ok || data.error) {
        bookError.textContent = data.error || "Booking failed. Please try again.";
        bookBtn.disabled = false;
        bookText.textContent = "Book Now";
        loader.style.display = "none";
        return;
      }

      if (data.url) {
        window.location.href = data.url;
        return;
      }

      success.textContent = data.message || "Booking confirmed! We'll contact you shortly.";
      success.style.display = "block";
      bookText.textContent = "Booked \u2713";
      loader.style.display = "none";

      if (data.redirect) {
        window.location.href = data.redirect;
      }
    } catch {
      bookError.textContent = "Could not connect to server. Please try again later.";
      bookBtn.disabled = false;
      bookText.textContent = "Book Now";
      loader.style.display = "none";
    }
  });
</script>

<style>
  .booking-section {
    padding: 48px 0;
  }

  .booking-container {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: 32px;
  }

  .booking-header {
    margin-bottom: 28px;
  }

  .booking-header h2 {
    font-size: 22px;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 4px;
  }

  .booking-subtitle {
    font-size: 14px;
    color: #94a3b8;
  }

  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 13px;
    font-weight: 600;
    color: #0f172a;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-input {
    padding: 12px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-input:focus {
    border-color: #0f172a;
  }

  .days-selector {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8fafc;
    border-radius: 10px;
    padding: 14px 16px;
  }

  .days-selector label {
    font-size: 12px;
    font-weight: 500;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .days-control {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .days-btn {
    width: 32px;
    height: 32px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: white;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #64748b;
    transition: all 0.2s;
  }

  .days-btn:hover {
    border-color: #94a3b8;
    color: #0f172a;
  }

  .days-value {
    font-size: 20px;
    font-weight: 700;
    color: #0f172a;
    min-width: 24px;
    text-align: center;
  }

  .price-breakdown {
    background: #f8fafc;
    border-radius: 10px;
    padding: 16px;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: #64748b;
    padding: 6px 0;
  }

  .price-row.total {
    border-top: 1px solid #e2e8f0;
    margin-top: 4px;
    padding-top: 12px;
    font-size: 18px;
    font-weight: 700;
    color: #0f172a;
  }

  .pay-btn {
    width: 100%;
    padding: 16px;
    background: #0f172a;
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: inherit;
  }

  .pay-btn:hover:not(:disabled) {
    background: #1e293b;
  }

  .pay-btn:disabled {
    background: #cbd5e1;
    cursor: not-allowed;
  }

  .book-error {
    font-size: 13px;
    color: #dc2626;
  }

  .book-success {
    font-size: 14px;
    color: #16a34a;
    font-weight: 500;
    text-align: center;
    padding: 12px;
    background: #f0fdf4;
    border-radius: 10px;
  }

  .loader {
    width: 20px;
    height: 20px;
    border: 2px solid white;
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
