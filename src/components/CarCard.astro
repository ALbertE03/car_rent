---
import { Image } from "astro:assets";
export interface Props {
  slug: string;
  color: string;
  model: string;
  brand: string;
  year: number;
  plate: string;
  pricePerDay: number;
  available: boolean;
  photos: { main: string };
}

const {
  slug,
  color,
  model,
  brand,
  year,
  plate,
  pricePerDay,
  available,
  photos,
} = Astro.props;
---

<a href={`/cars/${slug}`} class="car-card">
  <div class="card-image">
    <Image
      src={photos.main}
      alt={`${color} ${brand} ${model} ${year}`}
      width="240"
      height="180"
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="card-info">
    <h3>{color} {brand} {model}</h3>
    <span class="plate">{plate}</span>
    <div class="card-footer">
      <span class="price">${pricePerDay}<span>/day</span></span>
      {
        available ? (
          <span class="view-btn">View</span>
        ) : (
          <span class="view-btn disabled">Unavailable</span>
        )
      }
    </div>
  </div>
</a>

<style>
  .car-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    width: 200px;
    flex-shrink: 0;
  }

  .card-image {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    height: 180px;
    width: auto;
    max-width: 100%;
    display: block;
    object-fit: contain;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
    will-change: transform;
    position: relative;
    filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.08));
  }

  .car-card:hover .card-image img {
    transform: scale(1.2) translateY(15px);
    z-index: 999;
    filter: drop-shadow(0 10px 16px rgba(0, 0, 0, 0.12)) brightness(1.04);
  }

  .card-info {
    text-align: center;
    padding: 12px 0 0;
    width: 100%;
  }

  .card-info h3 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 2px;
    color: #0f172a;
  }

  .plate {
    font-size: 12px;
    color: #94a3b8;
    display: block;
    margin-bottom: 8px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .price {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.3px;
    color: #0f172a;
  }

  .price span {
    font-size: 11px;
    font-weight: 400;
    color: #94a3b8;
  }

  .view-btn {
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 8px;
    background: #0f172a;
    color: white;
    transition: background 0.2s;
  }

  .view-btn:hover {
    background: #1e293b;
  }

  .view-btn.disabled {
    background: #e2e8f0;
    color: #94a3b8;
    cursor: not-allowed;
  }

  @media (min-width: 1024px) {
    .car-card {
      width: 280px;
    }

    .card-image img {
      height: 250px;
    }

    .card-info h3 {
      font-size: 18px;
    }

    .plate {
      font-size: 14px;
    }

    .price {
      font-size: 22px;
    }

    .price span {
      font-size: 13px;
    }

    .view-btn {
      font-size: 14px;
      padding: 8px 18px;
    }
  }

  @media (max-width: 768px) {
    .car-card {
      width: 220px;
    }

    .card-image img {
      height: 180px;
    }
  }
</style>
