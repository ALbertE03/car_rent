---
export interface Props {
  slug: string;
  color: string;
  model: string;
  brand: string;
  year: number;
  plate: string;
  pricePerDay: number;
  available: boolean;
  photos: { front: string };
}

const {
  slug,
  color,
  model,
  brand,
  year,
  plate,
  pricePerDay,
  available,
  photos,
} = Astro.props;
---

<a href={`/cars/${slug}`} class="car-card">
  <div class="card-image">
    <img src={photos.front} alt={`${color} ${brand} ${model}`} loading="lazy" />
    {!available && <span class="badge unavailable">Long Term Rental</span>}
  </div>
  <div class="card-body">
    <div class="card-header">
      <h3>{color} {brand} {model}</h3>
      <span class="plate">{plate}</span>
    </div>
    <div class="card-footer">
      <span class="price">${pricePerDay}<span>/day</span></span>
      {
        available ? (
          <span class="view-btn">View Details</span>
        ) : (
          <span class="view-btn disabled">Unavailable</span>
        )
      }
    </div>
  </div>
</a>

<style>
  .car-card {
    display: block;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    margin: 3%;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .car-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .card-image {
    position: relative;
    aspect-ratio: 4/3;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s;
  }

  .car-card:hover .card-image img {
    transform: scale(1.05);
  }

  .badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge.unavailable {
    background: rgba(0, 0, 0, 0.8);
    color: white;
  }

  .card-body {
    padding: 20px;
  }

  .card-header {
    margin-bottom: 16px;
  }

  .card-header h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .plate {
    font-size: 13px;
    color: #999;
    font-weight: 500;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .price {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .price span {
    font-size: 13px;
    font-weight: 400;
    color: #999;
  }

  .view-btn {
    font-size: 13px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 8px;
    background: #1a1a1a;
    color: white;
    transition: background 0.2s;
  }

  .view-btn:hover {
    background: #333;
  }

  .view-btn.disabled {
    background: #e0e0e0;
    color: #999;
    cursor: not-allowed;
  }
</style>
