---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="admin-page">
    <div class="admin-container">
      <div class="admin-header">
        <a href="/" class="back-link">&larr; Back to site</a>
        <h1>Admin Panel</h1>
        <p class="subtitle">Configure Stripe integration</p>
      </div>

      <div class="admin-card">
        <h2>Stripe Settings</h2>
        <p class="field-desc">
          Enter your Stripe publishable key to enable card payments on the
          booking page. This is stored locally in your browser.
        </p>

        <div class="form-group">
          <label for="stripePk">Publishable Key</label>
          <input
            type="text"
            id="stripePk"
            placeholder="pk_live_..."
            class="admin-input"
          />
          <span class="field-hint"
            >Starts with <code>pk_live_</code> or <code>pk_test_</code></span
          >
        </div>

        <div class="form-group">
          <label for="stripeBackend">Backend URL</label>
          <input
            type="url"
            id="stripeBackend"
            placeholder="/api/create-payment"
            class="admin-input"
          />
          <span class="field-hint"
            >URL of your payment endpoint that creates Stripe PaymentIntents</span
          >
        </div>

        <button id="saveBtn" class="save-btn">Save Settings</button>
        <p id="saveMsg" class="save-msg" style="display:none"></p>
      </div>

      <div class="admin-card">
        <h2>How to get your Stripe keys</h2>
        <ol class="steps-list">
          <li>
            Go to <a
              href="https://dashboard.stripe.com/apikeys"
              target="_blank"
              rel="noopener">Stripe Dashboard → API Keys</a>
          </li>
          <li>
            Copy your <strong>Publishable key</strong> (starts with <code
              >pk_</code
            >)
          </li>
          <li>
            Set up a server endpoint (or use a serverless function) that creates
            a <code>PaymentIntent</code> using your <strong>Secret key</strong>
          </li>
          <li>Enter the publishable key and your backend URL above</li>
        </ol>
      </div>

      <div class="admin-card">
        <h2>Test Cards</h2>
        <table class="test-cards-table">
          <thead>
            <tr><th>Card Number</th><th>Result</th></tr>
          </thead>
          <tbody>
            <tr><td><code>4242 4242 4242 4242</code></td><td>Success</td></tr>
            <tr><td><code>4000 0000 0000 0002</code></td><td>Declined</td></tr>
            <tr
              ><td><code>4000 0025 0000 3155</code></td><td
                >Insufficient funds</td
              ></tr
            >
          </tbody>
        </table>
        <p class="field-hint" style="margin-top:12px">
          Use any future expiry date and any 3-digit CVC
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const pkInput = document.getElementById("stripePk") as HTMLInputElement;
  const backendInput = document.getElementById("stripeBackend") as HTMLInputElement;
  const saveBtn = document.getElementById("saveBtn") as HTMLButtonElement;
  const saveMsg = document.getElementById("saveMsg") as HTMLParagraphElement;

  pkInput.value = localStorage.getItem("stripe_pk") || "";
  backendInput.value = localStorage.getItem("stripe_backend") || "";

  saveBtn.addEventListener("click", () => {
    localStorage.setItem("stripe_pk", pkInput.value.trim());
    localStorage.setItem("stripe_backend", backendInput.value.trim());
    saveMsg.textContent = "Settings saved successfully!";
    saveMsg.style.display = "block";
    saveMsg.style.color = "#16a34a";
    setTimeout(() => {
      saveMsg.style.display = "none";
    }, 3000);
  });
</script>

<style>
  .admin-page {
    min-height: 100vh;
    padding: 48px 24px;
  }

  .admin-container {
    max-width: 640px;
    margin: 0 auto;
  }

  .admin-header {
    margin-bottom: 40px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
    color: #64748b;
    margin-bottom: 24px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #0f172a;
  }

  .admin-header h1 {
    font-size: 32px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .subtitle {
    font-size: 15px;
    color: #64748b;
  }

  .admin-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 24px;
  }

  .admin-card h2 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
    color: #0f172a;
  }

  .field-desc {
    font-size: 14px;
    color: #64748b;
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .admin-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    transition: border-color 0.2s;
    outline: none;
    box-sizing: border-box;
  }

  .admin-input:focus {
    border-color: #0f172a;
  }

  .field-hint {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    color: #94a3b8;
  }

  .field-hint code {
    background: #f1f5f9;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 12px;
  }

  .save-btn {
    width: 100%;
    padding: 14px;
    background: #0f172a;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 8px;
  }

  .save-btn:hover {
    background: #1e293b;
  }

  .save-msg {
    text-align: center;
    margin-top: 12px;
    font-size: 14px;
    font-weight: 500;
  }

  .steps-list {
    padding-left: 20px;
    font-size: 14px;
    color: #64748b;
    line-height: 1.8;
  }

  .steps-list a {
    color: #2563eb;
    text-decoration: underline;
  }

  .test-cards-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .test-cards-table th {
    text-align: left;
    font-weight: 600;
    color: #0f172a;
    padding: 8px 12px;
    border-bottom: 1px solid #e2e8f0;
  }

  .test-cards-table td {
    padding: 8px 12px;
    border-bottom: 1px solid #f1f5f9;
    color: #64748b;
  }

  .test-cards-table code {
    background: #f1f5f9;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .admin-page {
      padding: 32px 16px;
    }

    .admin-card {
      padding: 24px 20px;
    }
  }
</style>
